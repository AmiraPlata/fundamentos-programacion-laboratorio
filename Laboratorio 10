#include <iostream>
using namespace std;

int contarPares (int num) {
int digito, contador = 0;

while (num > 0) {
    digito = num % 10;

    if (digito % 2 == 0){
        contador ++;
    }
    num = num /10;
}
return contador;
}

int main (){
int numero;

