#include <iostream>
using namespace std;

int sumaHastaN(int N) {
int suma = 0;

for (int i = 1; i <= N; i++){
    suma = suma + i;
}
return suma;
}

int main (){
int N;

cout << "Ingrese un numero entero positivo (N): ";
cin >> N;

int resultado = sumaHastaN(N);

cout << "La suma desde 1 hasta " << N << " es: " << resultado << endl;

return 0;
}


