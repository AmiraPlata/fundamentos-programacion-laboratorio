#include <iostream>
using namespace std;

float calcularPromedio (int N) {
float nota, suma = 0;

for (int i = 1; i <= N; i++) {
    cout << "Ingrese la nota: " << i << ": ";
    cin >> nota;
    suma += nota;
}
float promedio = suma / N;
return promedio;
}

int main (){
int N;

cout << "Ingrese la cantidad de notas: ";
cin >> N;

float resultado = calcularPromedio (N);

cout << "El promedio es: " << resultado << endl;

return 0;

}




