#include <iostream>
using namespace std;

void leerFecha (int &dia, int &mes, int &anio){
cout << "Ingrese el dia: ";
cin >> dia;
cout << "Ingrese el mes: ";
cin >> mes;
cout << "Ingrese el anio: ";
cin >> anio;
}

string nombreMes(int mes){
switch (mes){
    case 1: return "Enero";
    case 2: return "Febrero";
    case 3: return "Marzo";
    case 4: return "Abril";
    case 5: return "Mayo";
    case 6: return "Junio";
    case 7: return "Julio";
    case 8: return "Agosto";
    case 9: return "Septiembre";
    case 10: return "Octubre";
    case 11: return "Noviembre";
    case 12: return "Diciembre";
    default: return "Mes invalido";
}
}

int convertirAnio(int anio){
if (anio <= 25){
    return 2000 + anio;
}else{
return 1900 + anio;
}
}

void LITERAL(int dia, int mes, int anio){
string mesTexto = nombreMes(mes);
int anioCompleto = convertirAnio(anio);

cout << dia << " de " << mesTexto << " de " << anioCompleto << endl;
}

int main (){
int dia, mes, anio;

leerFecha (dia, mes, anio);
LITERAL(dia, mes, anio);

return 0;
}





