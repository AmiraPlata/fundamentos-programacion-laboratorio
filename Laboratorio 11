#include <iostream>
using namespace std;

void leerDatos(float &x, int &y){
cout << "Ingrese la base (x): ";
cin >> x;
cout << "Ingrese la potencia (y): ";
cin >> y;
}

float POTENCIA(float x, int y){
float resultado = 1;

for (int i = 1; i <= y; i++) {
    resultado = resultado * x;
}
return resultado;
}

void mostrarResultado(float x, int y, float resultado){
    if (y == 0){
    cout << x << "^0 = 1" << endl;
    return;
    }
    cout << x << "^" << y << " = ";

    for (int i = 1; i <= y; i++) {
    cout << x;

    if (i < y){
        cout << " * ";
    }
    }
    cout << " = " << resultado << endl;
}

int main (){
float x, resultado;
int y;

leerDatos (x, y);
resultado = POTENCIA(x, y);
mostrarResultado(x, y, resultado);

return 0;
}




