#include <iostream>
#include <math.h>
using namespace std;

void leerDatos (float &R, int &n){
cout << "Ingrese numero real: ";
cin >> R;
cout << "Ingrese cantidad de decimales: ";
cin >> n;
}

float redondear(float R, int n){
float factor = pow(10, n);
float resultado = round (R * factor) / factor;
return resultado;
}

void mostrarResultado (float resultado){
cout << "Numero redondeado: " << resultado << endl;
}

int main (){
float R, resultado;
int n;

leerDatos (R, n);
resultado = redondear (R, n);
mostrarResultado(resultado);

return 0;
}
